# Tollgate environment configuration. Copy to .env and fill in.
#   cp .env.example .env
# .env is gitignored; never commit real secrets. These are loaded automatically by
# edge.config.load_config() (and by the cloud entrypoints) if a .env file is present.

# --- Cloud reasoning (Qwen-VL on Alibaba Cloud) ------------------------------
# The Qwen Cloud API key from the hackathon voucher. REQUIRED for live cloud calls;
# without it the edge loop still runs (in-band items act locally). Keep it secret.
DASHSCOPE_API_KEY=

# Vision model id and the DashScope OpenAI-compatible endpoint. Defaults shown; only
# override if your voucher region/model differs.
QWEN_MODEL=qwen3-vl-plus
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- Edge runtime ------------------------------------------------------------
# The deployed cloud reasoning endpoint the edge client calls (Function Compute URL).
# Leave blank to run local-only (no escalation); the loop never blocks on the cloud.
EDGE_CLOUD_URL=

# Serial port for the USB relay actuator. Leave blank to use the mock actuator so the
# loop still runs and logs without hardware (e.g. /dev/ttyUSB0 on Linux, COM3 on Windows).
EDGE_RELAY_PORT=

# --- Cloud function (Function Compute) ---------------------------------------
# Port the FC custom runtime listens on. FC sets this automatically in deployment;
# only set it for local testing of cloud/fc_deploy/handler.py.
FC_SERVER_PORT=9000

# --- HTTPS deployment (Caddy + DuckDNS, see docs/SAS_HTTPS.md) ----------------
# Needed only for the HTTPS stack (docker-compose.https.yml) so the deployed Pages site can
# call the reasoner without mixed-content blocking. Leave blank for the plain-HTTP stack.
# Lock CORS to your Pages origin so random sites can't drain the Qwen voucher ("*" = open).
CORS_ALLOW_ORIGIN=
DUCKDNS_SUBDOMAIN=
DUCKDNS_TOKEN=
